<% layout("/layouts/boilerplate") %>

<div class="filters-container">
    <div class="filters">
        <a href="/listings?category=Popular" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-fire"></i>
                <p>Popular</p>
            </div>
        </a>
    
        <a href="/listings?category=Event Halls" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-building"></i>
                <p>Event Halls</p>
            </div>
        </a>
    
        <a href="/listings?category=Wedding Venues" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-ring"></i>
                <p>Wedding Venues</p>
            </div>
        </a>
    
        <a href="/listings?category=Concert Spaces" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-music"></i>
                <p>Concert Spaces</p>
            </div>
        </a>
    
        <a href="/listings?category=Party Venues" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-champagne-glasses"></i>
                <p>Party Venues</p>
            </div>
        </a>
    
        <a href="/listings?category=Corporate Events" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-briefcase"></i>
                <p>Corporate</p>
            </div>
        </a>
    
        <a href="/listings?category=Banquet Halls" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-utensils"></i>
                <p>Banquet Halls</p>
            </div>
        </a>
    
        <a href="/listings?category=Outdoor Venues" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-tree"></i>
                <p>Outdoor</p>
            </div>
        </a>
    
        <a href="/listings?category=Photo Shoots" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-camera"></i>
                <p>Photo Shoots</p>
            </div>
        </a>
        <a href="/listings?category=Others" class="filter-link">
            <div class="filter">
                <i class="fa-solid fa-ellipsis"></i>
                <p>Others</p>
            </div>
        </a>
    </div>
</div>

<div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of AllListings) { %>
        <a href="/listings/<%=listing.id%>" class="listing-links">
            <div class="card listing-card mb-4">
                <img src="<%=listing.image.url%>" class="card-img-top" alt="venue_image" style="height: 20rem; object-fit: cover;">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <b><%= listing.title %></b> <br>
                        
                        <div class="mb-1">
                            <% if(listing.reviews && listing.reviews.length > 0) { %>
                                <span class="text-warning">
                                    <i class="fa-solid fa-star"></i> 
                                    <b><%= listing.avgRating %></b>
                                </span>
                                <span class="text-muted" style="font-size: 0.9rem;">
                                    (<%= listing.reviews.length %> <%= listing.reviews.length === 1 ? 'review' : 'reviews' %>)
                                </span>
                            <% } else { %>
                                <span class="text-muted small">
                                    <i class="fa-regular fa-star"></i> No reviews
                                </span>
                            <% } %>
                        </div>

                        &#8377; <%= listing.price.value.toLocaleString("en-IN") %> / <%= listing.price.unit %>
                    </p>
                </div>
            </div>
        </a>
    <% } %>
</div>